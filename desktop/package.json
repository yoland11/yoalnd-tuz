{
  "name": "@ajn/desktop",
  "version": "1.0.0",
  "description": "AJN ERP Windows Desktop application",
  "author": "AJN",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "compile": "tsc -p tsconfig.json",
    "build": "pnpm run compile && electron-builder --dir",
    "dist": "pnpm run compile && electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "electron": "39.8.5",
    "electron-builder": "26.15.3",
    "typescript": "~5.9.2"
  }
}
