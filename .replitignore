# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# No need to store the pnpm store twice.
.local

# Dependencies and package-manager caches should never be deployed.
node_modules
**/node_modules
.cache
.pnpm-store

# Build outputs are recreated during deployment.
dist
**/dist
out-tsc
*.tsbuildinfo

# Local/editor/history files.
.git
.config
.DS_Store
.env
.env.*
Replit Secrets

# Large source-transfer artifacts.
*.zip
*.tar
*.tgz
