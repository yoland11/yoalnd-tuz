{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.mjs",
    "dev": "sh -c 'pnpm run dev:api & pnpm run dev:web & wait'",
    "dev:api": "PORT=8080 pnpm --filter @workspace/api-server run dev",
    "dev:web": "PORT=20796 BASE_PATH=/ pnpm --filter @workspace/ajn-platform run dev",
    "codegen": "pnpm --filter @workspace/api-spec run codegen",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm --filter @workspace/db run seed",
    "audit": "pnpm audit --audit-level moderate",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
