# Core runtime
NODE_ENV=development
LOG_LEVEL=info

# Next.js fullstack runtime
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-customer-auth-secret
APP_BASE_URL=https://yoland-alijan.vercel.app/
PUBLIC_BASE_URL=https://yoland-alijan.vercel.app/

# First admin seed
# In production, set these before the first Next.js API login. The fallback password is
# allowed only outside production.
ADMIN_USERNAME=alijan
ADMIN_PASSWORD=change-this-before-production
ADMIN_FULL_NAME=المدير الرئيسي

# WhatsApp providers. Configure one provider, then enable events in the admin UI.
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
WASSENGER_API_KEY=
WASSENGER_DEVICE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000
META_WA_PHONE_ID=
META_WA_TOKEN=
